# Required at deploy time. On Cloud Run this is wired via Secret Manager
# (see deploy-api.yml: --set-secrets=GEMINI_API_KEY=gemini-api-key:latest).
GEMINI_API_KEY=

# Firebase Admin auto-detects credentials on Cloud Run via the default service account.
# For local dev, set GOOGLE_APPLICATION_CREDENTIALS to a service account key file:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# Firebase project (defaults to reais---prospecter if unset).
FIREBASE_PROJECT_ID=reais---prospecter
FIREBASE_STORAGE_BUCKET=reais---prospecter.firebasestorage.app

# Comma-separated allowlist for origins that may call the API. Default includes Cloud Run web and localhost.
ALLOWED_ORIGINS=https://deal-scout-s4vcjek4ra-uw.a.run.app,http://localhost:5173

# Comma-separated allowlist for emails/domains permitted to call protected endpoints.
ALLOWED_EMAILS=pinekrone@gmail.com
ALLOWED_DOMAINS=realestateaistudio.com

# Gemini model used for vision extraction. Defaults to gemini-2.5-pro.
GEMINI_MODEL=gemini-2.5-pro
