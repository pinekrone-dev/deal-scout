rules_version = '2';

// Deal Scout CRM. Multi-tenant: every doc has owner_uid = creating user's uid.
// Any authenticated Firebase user can sign in. Users can only read/write docs they own.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(data) {
      return signedIn() && data.owner_uid == request.auth.uid;
    }

    function willOwn() {
      return signedIn() && request.resource.data.owner_uid == request.auth.uid;
    }

    // Per-user profile. Stores personal settings such as the user's Gemini API key.
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /buildings/{id} {
      allow read: if isOwner(resource.data);
      allow create: if willOwn();
      allow update: if isOwner(resource.data) && request.resource.data.owner_uid == resource.data.owner_uid;
      allow delete: if isOwner(resource.data);
    }

    match /contacts/{id} {
      allow read: if isOwner(resource.data);
      allow create: if willOwn();
      allow update: if isOwner(resource.data) && request.resource.data.owner_uid == resource.data.owner_uid;
      allow delete: if isOwner(resource.data);
    }

    match /deals/{id} {
      allow read: if isOwner(resource.data);
      allow create: if willOwn();
      allow update: if isOwner(resource.data) && request.resource.data.owner_uid == resource.data.owner_uid;
      allow delete: if isOwner(resource.data);
    }

    match /underwriting/{id} {
      allow read: if isOwner(resource.data);
      allow create: if willOwn();
      allow update: if isOwner(resource.data) && request.resource.data.owner_uid == resource.data.owner_uid;
      allow delete: if isOwner(resource.data);
    }

    match /om_ingestions/{id} {
      allow read: if isOwner(resource.data);
      allow create: if willOwn();
      allow update: if isOwner(resource.data) && request.resource.data.owner_uid == resource.data.owner_uid;
      allow delete: if isOwner(resource.data);
    }
  }
}
